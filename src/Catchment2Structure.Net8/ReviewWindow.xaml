<Window x:Class="Catchment2Structure.ReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Catchment to Structure - Review Unresolved"
        Width="1000" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#FF3B4453"
        Foreground="#FFEAEAEA"
        FontFamily="Segoe UI"
        FontSize="12">

    <Window.Resources>
        <SolidColorBrush x:Key="C3D_WindowBg" Color="#FF3B4453"/>
        <SolidColorBrush x:Key="C3D_PanelBg" Color="#FF2E3440"/>
        <SolidColorBrush x:Key="C3D_HeaderBg" Color="#FF454F61"/>
        <SolidColorBrush x:Key="C3D_RowBg" Color="#FF36404F"/>
        <SolidColorBrush x:Key="C3D_RowAltBg" Color="#FF333C4B"/>
        <SolidColorBrush x:Key="C3D_Border" Color="#FF566072"/>
        <SolidColorBrush x:Key="C3D_Text" Color="#FFEAEAEA"/>
        <SolidColorBrush x:Key="C3D_AccentBlue" Color="#FF0998D8"/>
        <SolidColorBrush x:Key="C3D_AccentBlueHover" Color="#FF0BA3E8"/>
        <SolidColorBrush x:Key="C3D_AccentBluePressed" Color="#FF077FB3"/>

        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="BorderBrush" Value="{StaticResource C3D_Border}"/>
            <Setter Property="Background" Value="{StaticResource C3D_WindowBg}"/>
            <Setter Property="Foreground" Value="{StaticResource C3D_Text}"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="Foreground" Value="{StaticResource C3D_Text}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource C3D_AccentBlue}"/>
            <Setter Property="BorderBrush" Value="{StaticResource C3D_AccentBlue}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource C3D_AccentBlueHover}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource C3D_AccentBlueHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource C3D_AccentBluePressed}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource C3D_AccentBluePressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="RowBackground" Value="{StaticResource C3D_RowBg}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource C3D_RowAltBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource C3D_Border}"/>
            <Setter Property="Background" Value="{StaticResource C3D_WindowBg}"/>
            <Setter Property="Foreground" Value="{StaticResource C3D_Text}"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource C3D_HeaderBg}"/>
            <Setter Property="Foreground" Value="{StaticResource C3D_Text}"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource C3D_AccentBlue}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource C3D_HeaderBg}" Padding="10" BorderBrush="{StaticResource C3D_Border}" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Review Unresolved"/>
                    <TextBlock FontSize="12" Opacity="0.9" Text="Go To to view. Assign to connect a catchment to a structure, or Skip to leave it unassigned."/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1" Margin="12">
            <GroupBox Header="Items requiring review">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Margin="4,2,4,8" TextWrapping="Wrap">
                        Select an item and use Go To to view it. Use Assign to connect the catchment to a structure, or Skip to leave it unassigned.
                    </TextBlock>

                    <DataGrid Grid.Row="1" x:Name="ItemsGrid" SelectionChanged="ItemsGrid_SelectionChanged"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              CanUserResizeRows="False"
                              CanUserSortColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Type" Binding="{Binding TypeLabel}" Width="230"/>
                            <DataGridTextColumn Header="Catchment" Binding="{Binding CatchmentName}" Width="*"/>
                            <DataGridTextColumn Header="Candidates" Binding="{Binding CandidateCount}" Width="110"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Notes}" Width="260"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource C3D_HeaderBg}" Padding="10" BorderBrush="{StaticResource C3D_Border}" BorderThickness="0,1,0,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="GoToBtn" Content="Go To" Width="110" Height="30" Click="GoTo_Click"/>
                    <Button x:Name="AssignBtn" Content="Assign" Width="110" Height="30" Click="Assign_Click"/>
                    <Button x:Name="SkipBtn" Content="Skip" Width="110" Height="30" Click="Skip_Click"/>
                    <Button x:Name="FinishBtn" Content="Finish" Width="110" Height="30" Click="Finish_Click"/>
                    <Button Content="Close" Width="110" Height="30" Click="Close_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
