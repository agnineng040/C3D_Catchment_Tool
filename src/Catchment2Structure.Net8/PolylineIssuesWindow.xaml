<Window x:Class="Catchment2Structure.PolylineIssuesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Catchment to Structure - Polyline Conversion Issues"
        Width="980" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#FF3B4453"
        Foreground="#FFEAEAEA"
        FontFamily="Segoe UI"
        FontSize="12">

    <Window.Resources>
        <SolidColorBrush x:Key="C3D_WindowBg" Color="#FF3B4453"/>
        <SolidColorBrush x:Key="C3D_PanelBg" Color="#FF2E3440"/>
        <SolidColorBrush x:Key="C3D_HeaderBg" Color="#FF454F61"/>
        <SolidColorBrush x:Key="C3D_Border" Color="#FF566072"/>
        <SolidColorBrush x:Key="C3D_Text" Color="#FFEAEAEA"/>
        <SolidColorBrush x:Key="C3D_AccentBlue" Color="#FF0998D8"/>
        <SolidColorBrush x:Key="C3D_AccentBlueHover" Color="#FF0BA3E8"/>
        <SolidColorBrush x:Key="C3D_AccentBluePressed" Color="#FF077FB3"/>

        <Style TargetType="Button">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource C3D_AccentBlue}"/>
            <Setter Property="BorderBrush" Value="{StaticResource C3D_AccentBlue}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource C3D_AccentBlueHover}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource C3D_AccentBlueHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource C3D_AccentBluePressed}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource C3D_AccentBluePressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Margin" Value="10"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="Background" Value="{StaticResource C3D_PanelBg}"/>
            <Setter Property="Foreground" Value="{StaticResource C3D_Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource C3D_Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="{StaticResource C3D_PanelBg}"/>
            <Setter Property="AlternatingRowBackground" Value="#FF2A2F3A"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource C3D_HeaderBg}"/>
            <Setter Property="Foreground" Value="{StaticResource C3D_Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource C3D_Border}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource C3D_HeaderBg}" Padding="10" BorderBrush="{StaticResource C3D_Border}" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Polyline Conversion Issues"/>
                <TextBlock DockPanel.Dock="Right" Opacity="0.85" VerticalAlignment="Center" Text="(Fix polylines and re-run conversion)"/>
            </DockPanel>
        </Border>

        <!-- Body -->
        <DataGrid Grid.Row="1" x:Name="IssuesGrid" SelectionChanged="IssuesGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Handle" Binding="{Binding Handle}" Width="110"/>
                <DataGridTextColumn Header="Layer" Binding="{Binding Layer}" Width="180"/>
                <DataGridTextColumn Header="# Verts" Binding="{Binding VertexCount}" Width="90"/>
                <DataGridTextColumn Header="Focus (X,Y)" Binding="{Binding Focus}" Width="140"/>
                <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource C3D_HeaderBg}" Padding="10" BorderBrush="{StaticResource C3D_Border}" BorderThickness="0,1,0,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button x:Name="GoToBtn" Content="Go To" Width="110" Height="30" Click="GoTo_Click" IsEnabled="False"/>
                    <Button x:Name="SelectBtn" Content="Select" Width="110" Height="30" Click="Select_Click" IsEnabled="False"/>
                    <Button x:Name="CopyHandleBtn" Content="Copy Handle" Width="130" Height="30" Click="CopyHandle_Click" IsEnabled="False"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Close" Width="110" Height="30" Click="Close_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
